# Supabase (required for auth and database)
# Get these from: https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Optional: for Stripe webhook (create purchase / mark sold). Dashboard > Developers > Webhooks
SUPABASE_SERVICE_ROLE_KEY=

# Stripe (optional: card & Apple Pay checkout)
# Get from: https://dashboard.stripe.com/apikeys and https://dashboard.stripe.com/webhooks
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# App URL for checkout redirects (e.g. https://yourdomain.com). Leave blank for Vercel auto URL.
NEXT_PUBLIC_APP_URL=
