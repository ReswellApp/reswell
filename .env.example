# Supabase (required for auth and database)
# Get these from: https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Optional: for Stripe webhook (create purchase / mark sold). Dashboard > Developers > Webhooks
SUPABASE_SERVICE_ROLE_KEY=

# Cloudflare: this app talks to Supabase over HTTPS (PostgREST) via supabase-js — not raw Postgres.
# On Cloudflare Pages, set the same NEXT_PUBLIC_SUPABASE_* (and server-only keys) in the project Environment variables.
# Cloudflare D1 is SQLite (separate product); it does not “host” your Supabase data unless you build a sync yourself.
# For Cloudflare Workers that run SQL with node-postgres/pg, use Hyperdrive → Supabase Postgres (direct connection string):
# https://developers.cloudflare.com/hyperdrive/examples/connect-to-postgres/supabase/

# Stripe — required for card checkout + Connect V2 (peer payouts). Test: sk_test_... / pk_test_...
# See docs/STRIPE.md
STRIPE_SECRET_KEY=
# Optional: only if your secret key is from a parent org (not the Connect platform account).
# V2 Connect then needs Stripe-Context = this_platform_acct / connected_acct
# STRIPE_PLATFORM_ACCOUNT_ID=acct_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Webhook signing secret (whsec_...) from Stripe CLI or Dashboard.
# Local Connect V2 thin events + Checkout: npm run stripe:listen
STRIPE_WEBHOOK_SECRET=

# Base URL for Connect return/refresh links and checkout (e.g. http://localhost:3000 locally, https://reswell.app in production)
NEXT_PUBLIC_URL=

# App URL for Stripe redirects and canonical metadata (see lib/public-site-origin.ts). Production: https://reswell.app
# Google OAuth callback uses the browser’s origin (see lib/auth/oauth-callback-url.ts). In Supabase → Authentication →
# URL Configuration → Redirect URLs, add every origin you use, e.g. http://localhost:3000/auth/callback and https://reswell.app/auth/callback.
NEXT_PUBLIC_APP_URL=

# Optional: same as NEXT_PUBLIC_APP_URL for some deploys; publicSiteOrigin() prefers SITE_URL then APP_URL.
# NEXT_PUBLIC_SITE_URL=https://reswell.app

# Anthropic Claude — optional; powers “Write description for me” for surfboard listings on /sell
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Klaviyo — optional; server-side Events API (private key with Events: Write)
# Metrics: "Signed Up" (welcome flow; OAuth + email signup confirm), "Listing" (create listing), "Message Sent" (event profile = message recipient; SUPABASE_SERVICE_ROLE_KEY fills their email for Klaviyo profile + flows)
# Debug: GET /api/integrations/klaviyo/status (returns whether the key is set, never the value)
# https://www.klaviyo.com/settings/account/api-keys
KLAVIYO_API_KEY=

# Elasticsearch (optional — powers /search when URL + auth are set)
# Elastic Cloud: project URL + API key from https://cloud.elastic.co
ELASTICSEARCH_URL=
ELASTICSEARCH_API_KEY=
# Or self-hosted basic auth:
# ELASTICSEARCH_USERNAME=
# ELASTICSEARCH_PASSWORD=
# Local Docker with no security only:
# ELASTICSEARCH_ALLOW_ANONYMOUS=true
# Index name (default: reswell_listings)
# ELASTICSEARCH_LISTINGS_INDEX=reswell_listings

# POST /api/search/reindex — Bearer token for CI/scripts (optional; admin UI works without it)
# SEARCH_REINDEX_SECRET=

# POST /api/search/es-webhook — Supabase Database Webhook secret header
SUPABASE_ES_WEBHOOK_SECRET=

# PayPal Payouts + Log in with PayPal (Dashboard → Apps & credentials)
# Use sandbox until PayPal approves Payouts on the business account.
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
# sandbox | live
PAYPAL_MODE=sandbox
# Same client ID as PAYPAL_CLIENT_ID — exposed to the browser for OAuth authorize URL
NEXT_PUBLIC_PAYPAL_CLIENT_ID=
# Site origin for PayPal redirect_uri (must match Return URL host). Local: http://localhost:3000
NEXT_PUBLIC_URL=http://localhost:3000
