# Supabase (required for auth and database)
# Get these from: https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Optional: for Stripe webhook (create purchase / mark sold). Dashboard > Developers > Webhooks
SUPABASE_SERVICE_ROLE_KEY=

# Stripe (optional: card & Apple Pay checkout)
# Get from: https://dashboard.stripe.com/apikeys and https://dashboard.stripe.com/webhooks
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# App URL for checkout redirects (e.g. https://yourdomain.com). Leave blank for Vercel auto URL.
NEXT_PUBLIC_APP_URL=

# Elasticsearch (optional — powers /search when set)
# Elastic Cloud: project URL + API key from https://cloud.elastic.co
ELASTICSEARCH_URL=
ELASTICSEARCH_API_KEY=
# Or self-hosted basic auth:
# ELASTICSEARCH_USERNAME=
# ELASTICSEARCH_PASSWORD=
# Index name (default: reswell_listings)
# ELASTICSEARCH_LISTINGS_INDEX=reswell_listings

# POST /api/search/reindex — Bearer token for CI/scripts (optional; admin UI works without it)
# SEARCH_REINDEX_SECRET=

# POST /api/search/es-webhook — Supabase Database Webhook secret header
SUPABASE_ES_WEBHOOK_SECRET=
